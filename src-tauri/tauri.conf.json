{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "firewood",
  "version": "0.5.1",
  "identifier": "com.ifmagic.firewood",
  "mainBinaryName": "firewood",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "Firewood",
        "width": 800,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [],
    "targets": ["nsis", "dmg"],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCREFCN0MxQjA3RTZFMjEKUldRaGJuNnd3YmZheTM0TzRkdFFuNDRwcW4wZ3VrZnJOb2FPMjV2OGtWZG5yQ3FrUjFYaU04TlMK",
      "endpoints": [
        "https://github.com/ifmagic/firewood/releases/latest/download/latest.json"
      ]
    }
  }
}
